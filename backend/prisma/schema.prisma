generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  suspended
  deleted
}

enum AuthProvider {
  email
  google
}

enum AuthTokenType {
  email_verification
  password_reset
}

enum PostStatus {
  draft
  published
}

enum LinkType {
  portfolio
  github
  linkedin
  x
  other
}

enum AssetType {
  avatar
  cover_image
  other
}

enum ViewSource {
  profile
  post
  embed
  unknown
}

model User {
  id        String     @id @db.Uuid
  status    UserStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?  @map("deleted_at") @db.Timestamptz(6)

  profile        Profile?
  authIdentities AuthIdentity[]
  authTokens     AuthToken[]
  posts          Post[]
  mediaAssets    MediaAsset[]

  @@map("users")
}

model AuthIdentity {
  id              String       @id @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  provider        AuthProvider
  providerUserId  String?      @map("provider_user_id")
  email           String?
  passwordHash    String?      @map("password_hash")
  emailVerifiedAt DateTime?    @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?    @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  authTokens AuthToken[]

  @@unique([provider, providerUserId])
  @@unique([provider, email])
  @@index([userId])
  @@map("auth_identities")
}

model AuthToken {
  id         String        @id @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  identityId String?       @map("identity_id") @db.Uuid
  tokenHash  String        @unique @map("token_hash")
  tokenType  AuthTokenType @map("token_type")
  expiresAt  DateTime      @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime?     @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  identity AuthIdentity? @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([userId, tokenType, createdAt(sort: Desc)])
  @@index([tokenType, expiresAt])
  @@map("auth_tokens")
}

model Profile {
  id            String   @id @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  username      String   @unique
  displayName   String   @map("display_name")
  bio           String?
  avatarMediaId String?  @map("avatar_media_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  avatarMedia MediaAsset? @relation("ProfileAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  links       ProfileLink[]

  @@map("profiles")
}

model ProfileLink {
  id        String   @id @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  linkType  LinkType @map("link_type")
  label     String?
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@index([profileId, position])
  @@map("profile_links")
}

model MediaAsset {
  id            String    @id @db.Uuid
  ownerUserId   String    @map("owner_user_id") @db.Uuid
  storageKey    String    @unique @map("storage_key")
  publicUrl     String    @map("public_url")
  mimeType      String    @map("mime_type")
  fileSizeBytes BigInt    @map("file_size_bytes")
  width         Int?
  height        Int?
  assetType     AssetType @map("asset_type")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  owner     User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  avatarFor Profile[] @relation("ProfileAvatar")
  coverFor  Post[]    @relation("PostCover")

  @@index([ownerUserId, createdAt(sort: Desc)])
  @@map("media_assets")
}

model Post {
  id           String     @id @db.Uuid
  authorUserId String     @map("author_user_id") @db.Uuid
  title        String
  slug         String
  status       PostStatus @default(draft)
  contentJson  Json       @default("{}") @map("content_json") @db.JsonB
  contentText  String?    @map("content_text")
  excerpt      String?
  coverMediaId String?    @map("cover_media_id") @db.Uuid
  publishedAt  DateTime?  @map("published_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  author     User        @relation(fields: [authorUserId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  coverMedia MediaAsset? @relation("PostCover", fields: [coverMediaId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  postTags   PostTag[]
  viewsDaily PostViewsDaily[]

  @@unique([authorUserId, slug])
  @@index([authorUserId, status, updatedAt(sort: Desc)])
  @@index([authorUserId, status, publishedAt(sort: Desc)])
  @@map("posts")
}

model Tag {
  id        String   @id @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  postTags PostTag[]

  @@map("tags")
}

model PostTag {
  postId    String   @map("post_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Restrict)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@id([postId, tagId])
  @@index([tagId, postId])
  @@map("post_tags")
}

model PostViewsDaily {
  postId     String     @map("post_id") @db.Uuid
  viewDate   DateTime   @map("view_date") @db.Date
  source     ViewSource @default(unknown)
  viewsCount Int        @default(0) @map("views_count")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: Restrict)

  @@id([postId, viewDate, source])
  @@index([viewDate])
  @@map("post_views_daily")
}
