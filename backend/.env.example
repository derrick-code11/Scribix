# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Auth (Supabase JWT verification via JWKS) ---
# Same URL as the frontend VITE_SUPABASE_URL (https://xxx.supabase.co, no trailing slash).
SUPABASE_URL=

# --- Database (Prisma) ---
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE

# --- AWS S3 + CloudFront ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
CLOUDFRONT_BASE_URL=
