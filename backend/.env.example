# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated; include the exact browser origin used for the frontend dev server.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Public frontend base URL used for absolute embed links.
PUBLIC_APP_URL=""

# --- Database (Prisma) ---
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE

# --- AWS S3 + CloudFront ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
CLOUDFRONT_BASE_URL=
